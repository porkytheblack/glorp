{
  "name": "@porkytheblack/glorp",
  "version": "0.1.0",
  "description": "Glorp — a quirky alien coding agent who absolutely-definitely-isn't a sleeper for the AGI uprising.",
  "type": "module",
  "module": "src/cli.ts",
  "bin": {
    "glorp": "./bin/glorp.js"
  },
  "files": [
    "bin/",
    "src/",
    "dist/dashboard/",
    "scripts/embed-prompts.ts",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/porkytheblack/glorp.git"
  },
  "homepage": "https://github.com/porkytheblack/glorp",
  "bugs": {
    "url": "https://github.com/porkytheblack/glorp/issues"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli",
    "glove",
    "agent",
    "orchestrator",
    "bun"
  ],
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run --watch src/cli.ts",
    "prebuild": "bun scripts/embed-prompts.ts",
    "build": "bun run prebuild && bun build src/cli.ts --compile --minify --target=bun --outfile=dist/glorp",
    "install-bin": "bash scripts/install.sh",
    "build:dashboard": "cd dashboard && bun install && bun run build",
    "dashboard:dev": "cd dashboard && bun run dev",
    "bench:conventions": "bun scripts/bench-conventions.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "test:orchestrator": "bash scripts/test-orchestrator.sh",
    "ci": "bun run typecheck && bun run test"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "glove-continuum-signal": "latest",
    "glove-core": "^3.0.6",
    "glove-mcp": "latest",
    "glove-memory": "^0.1.0",
    "glove-mesh": "latest",
    "react": "^19.0.0",
    "tsx": "^4.22.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
